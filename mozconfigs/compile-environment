if [ -z $ARTIFACT_BUILD ] && [ ! -z $ANDROID_BUILD ]; then
  ANDROID_NDK_DIR=$(ls -r $MOZBUILD | grep '^android-ndk-' | head -n 1)
  ac_add_options --with-android-ndk=$MOZBUILD/$ANDROID_NDK_DIR
fi

if [ -z $ARTIFACT_BUILD ]; then
  if [ ! -z "$CC" ]; then
    if [ -z "$HOST_CC" ]; then
      export HOST_CC="$CC"
    fi
    if [ -z "$HOST_CXX" ]; then
      export HOST_CXX="$CXX"
    fi
  fi
  if [ -z $CACHE ]; then
    if command -v ccache >/dev/null; then
      ac_add_options --with-ccache=ccache
      # See https://ccache.dev/manual/latest.html#_compiling_in_different_directories
      mk_add_options 'export CCACHE_NOHASHDIR=1'
      mk_add_options 'export CCACHE_BASEDIR=@TOPSRCDIR@'
      # This helps with warnings and so on.
      mk_add_options 'export CCACHE_ABSSTDERR=1'
    fi
  fi
fi
